{
  "manifest_version": 3,
  "name": "TrustMesh Sentinel",
  "version": "1.0",
  "description": "Verify image authenticity using TrustMesh",

  "permissions": ["activeTab"],
  "host_permissions": [
    "http://localhost:3000/*",
    "http://127.0.0.1:3000/*"
  ],

  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"]
    }
  ],

  "action": {
    "default_popup": "popup.html"
  }
}